{
  "name": "partyline",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "pnpm --filter @partyline/server start",
    "test": "turbo test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo typecheck",
    "test:e2e": "playwright test",
    "ci:gate": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "lefthook",
      "msgpackr-extract",
      "playwright",
      "sharp"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.0.0",
    "lefthook": "^1.9.4",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
