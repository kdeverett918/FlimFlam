{
  "name": "flimflam",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "node scripts/cloud-build.mjs",
    "build:all": "turbo build --concurrency=1",
    "start": "pnpm --filter @flimflam/server start",
    "test": "turbo test",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo typecheck",
    "test:e2e": "node scripts/test-e2e.mjs",
    "ci:gate": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "next": "15.1.0",
    "tsx": "^4.19.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "lefthook",
      "msgpackr-extract",
      "playwright",
      "sharp"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "colyseus.js": "^0.15.28",
    "lefthook": "^1.9.4",
    "sharp": "^0.34.5",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
