# ─── Host App — Production Build Env ─────────────────────────────────────────
# Committed to git (no secrets here — NEXT_PUBLIC_* vars are baked into the JS
# bundle at build time and are publicly visible regardless).
#
# Render service name: flimflam-host
# Controller service name: flimflam-controller (deployed first)
# ─────────────────────────────────────────────────────────────────────────────

# Colyseus game server (Colyseus Cloud — deployed)
NEXT_PUBLIC_COLYSEUS_URL=wss://us-dfw-baad7ee4.colyseus.cloud

# Controller app URL — baked into QR codes and "JOIN AT" display on lobby screen.
# Must match the Render service name chosen for apps/controller.
NEXT_PUBLIC_CONTROLLER_URL=https://flimflam-controller.onrender.com

# Suppress Next.js telemetry in production builds
NEXT_TELEMETRY_DISABLED=1
