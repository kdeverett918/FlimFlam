{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "apps/**/*",
    "games/**/*",
    "packages/**/*",
    "scripts/**/*",
    "tests/**/*",
    "docs/**/*"
  ],
  "exclude": [
    ".tmp",
    "node_modules",
    "dist",
    ".next",
    ".turbo",
    "playwright-report",
    "test-results"
  ]
}

