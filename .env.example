# ─── FLIMFLAM Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local for local development (gitignored).
# Production values live in apps/web/.env.production (committed, no secrets)
# plus service-level runtime env on Render for non-public values.
#
# The ONLY secret that needs manual configuration is ANTHROPIC_API_KEY,
# which must be set in the Colyseus Cloud dashboard (server-side only).
# ─────────────────────────────────────────────────────────────────────────────


# ── Colyseus Game Server ──────────────────────────────────────────────────────
# WebSocket URL for the Colyseus game server.
# Local dev:    ws://localhost:2567  (default, no need to set)
# Production:   wss://us-dfw-baad7ee4.colyseus.cloud  (set in apps/web/.env.production)
NEXT_PUBLIC_COLYSEUS_URL=ws://localhost:2567


# ── Frontend App URLs ─────────────────────────────────────────────────────────
# Local dev:    http://localhost:3000
# Production:   https://flimflam.gg  (set in apps/web/.env.production)
NEXT_PUBLIC_HOST_URL=http://localhost:3000

# Optional dedicated FlimFlap destination. If unset, the landing card falls
# back to the temporary legacy alias route at /trumpybird.
# NEXT_PUBLIC_FLIMFLAP_URL=https://flimflap.com

# Native-hosted FlimFlap frontend served by the Next app at /flimflap.
# Local dev default is http://127.0.0.1:2567 if this is unset.
# Production should point at the FlimFlap backend service.
# FLIMFLAP_BACKEND_URL=http://127.0.0.1:2567
# Legacy alias still supported by the wrapper page:
# TRUMPYBIRD_BACKEND_URL=http://127.0.0.1:2567


# ── FlimFlap Supabase Backend ────────────────────────────────────────────────
# Required for FlimFlap login, save sync, and account-backed progression.
# SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...


# ── AI / Anthropic ────────────────────────────────────────────────────────────
# Required on the COLYSEUS SERVER (not the Next.js apps) for AI-powered games:
#   World Builder, Bluff Engine, Reality Drift, Hot Take (player-input mode).
#
# Local dev:    Set in your shell or packages/server/.env.local
# Production:   Set in Colyseus Cloud dashboard → Environment Variables
#               (NEVER commit a real key to git)
ANTHROPIC_API_KEY=sk-ant-...


# ── Server Runtime (set automatically in production) ─────────────────────────
# These are managed by the platform — no manual action needed.
# NODE_ENV=production           ← set by Render / Colyseus Cloud
# COLYSEUS_CLOUD=1              ← injected by Colyseus Cloud automatically
# PORT=<n>                      ← injected by Render / PM2 automatically
# NODE_APP_INSTANCE=<n>         ← injected by PM2 automatically
