# ─── FLIMFLAM Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local for local development (gitignored).
# Production values live in apps/host/.env.production and
# apps/controller/.env.production (committed, no secrets).
#
# The ONLY secret that needs manual configuration is ANTHROPIC_API_KEY,
# which must be set in the Colyseus Cloud dashboard (server-side only).
# ─────────────────────────────────────────────────────────────────────────────


# ── Colyseus Game Server ──────────────────────────────────────────────────────
# WebSocket URL for the Colyseus game server.
# Local dev:    ws://localhost:2567  (default, no need to set)
# Production:   wss://us-dfw-baad7ee4.colyseus.cloud  (set in .env.production)
NEXT_PUBLIC_COLYSEUS_URL=ws://localhost:2567


# ── Frontend App URLs ─────────────────────────────────────────────────────────
# Used by the HOST app to generate QR codes and the "JOIN AT" lobby display.
# Local dev:    http://localhost:3001  (default, no need to set)
# Production:   https://play.flimflam.gg  (set in host .env.production)
NEXT_PUBLIC_CONTROLLER_URL=http://localhost:3001

# NEXT_PUBLIC_HOST_URL is only used in Playwright E2E test configs — not needed
# in app code or production deployments.
# NEXT_PUBLIC_HOST_URL=http://localhost:3000


# ── AI / Anthropic ────────────────────────────────────────────────────────────
# Required on the COLYSEUS SERVER (not the Next.js apps) for AI-powered games:
#   World Builder, Bluff Engine, Reality Drift, Hot Take (player-input mode).
#
# Local dev:    Set in your shell or packages/server/.env.local
# Production:   Set in Colyseus Cloud dashboard → Environment Variables
#               (NEVER commit a real key to git)
ANTHROPIC_API_KEY=sk-ant-...


# ── Server Runtime (set automatically in production) ─────────────────────────
# These are managed by the platform — no manual action needed.
# NODE_ENV=production           ← set by Render / Colyseus Cloud
# COLYSEUS_CLOUD=1              ← injected by Colyseus Cloud automatically
# PORT=<n>                      ← injected by Render / PM2 automatically
# NODE_APP_INSTANCE=<n>         ← injected by PM2 automatically
