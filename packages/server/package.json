    "@flimflam/brain-battle": "workspace:*",
    "@flimflam/jeopardy": "workspace:*",
    "@flimflam/wheel-of-fortune": "workspace:*",
    "@flimflam/family-feud": "workspace:*",
    "colyseus": "^0.15.55",
    "@colyseus/schema": "^2.0.35",
    "@colyseus/monitor": "^0.16.7",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "tsx": "^4.19.3"
